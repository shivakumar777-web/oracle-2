# Cloud LLM: OpenRouter only (models: repo config/cloud_inference.yaml).
OPENROUTER_API_KEY=
OPENROUTER_API_KEY_2=
CLOUD_INFERENCE_CONFIG_PATH=
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=Manthana Oracle

# Embeddings: Ollama nomic-embed-text for Qdrant vector search
EMBED_URL=http://localhost:11434
QDRANT_URL=http://localhost:6333
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=masterKey
LOG_LEVEL=INFO
MAX_UPLOAD_MB=50
DEVICE=cpu
ENABLE_GPU=false

ECG_URL=http://ecg:8102
EYE_URL=http://eye:8103
CANCER_URL=http://cancer:8104
PATHOLOGY_URL=http://pathology:8105
BRAIN_URL=http://brain:8106
SEGMENTATION_URL=http://segmentation:8107
NLP_URL=http://nlp:8108
DRUG_URL=http://drug:8109
