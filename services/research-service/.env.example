# Research service — copy to .env
# Hybrid Deep Research (GPT Researcher) uses SearXNG only — set SEARXNG_URL and mirror for GR:
#   RETRIEVER=searx
#   SEARX_URL=<same as SEARXNG_URL with trailing slash>
# The service sets these automatically when hybrid runs from SEARXNG_URL.

RESEARCH_USE_LEGACY_RAG=true
SEARXNG_URL=http://searxng:8080

# Optional hybrid tuning
# RESEARCH_HYBRID_MAX_STEPS=0
# RESEARCH_HYBRID_TIMEOUT_SECONDS=0
# RESEARCH_GR_LLM=openrouter:deepseek/deepseek-chat
# RESEARCH_GR_EMBEDDING=openrouter:openai/text-embedding-3-small
# RESEARCH_PLAGIARISM_USE_QDRANT=true

OPENROUTER_API_KEY=
