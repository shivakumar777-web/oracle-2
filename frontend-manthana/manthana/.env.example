# ============================================================================
# MANTHANA — Oracle + Labs (slim product)
# Copy to .env.local (gitignored). Never commit real values.
#
# Manthana Web + Med Deep Research are disconnected in prod: keep
# NEXT_PUBLIC_MANTHANA_WEB_LOCKED=true and omit NEXT_PUBLIC_FULL_MANTHANA_NAV.
# ============================================================================

# ----------------------------------------------------------------------------
# SUPABASE — required for auth (fixes “Authentication is not configured” on Vercel)
# ----------------------------------------------------------------------------
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Use ONE of the two public keys (whichever your project shows):
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# Server-only: Labs trial counter, Razorpay/profile fixes. REQUIRED in production.
SUPABASE_SERVICE_ROLE_KEY=

# Dashboard → Authentication → URL configuration
#   Site URL: https://manthana.quaasx108.com (prod) or http://localhost:3001 (dev)
#   Redirect URLs: https://manthana.quaasx108.com/** and http://localhost:3001/**
#   Include: https://manthana.quaasx108.com/auth/callback
# Google OAuth: Providers → Google; in Google Cloud use redirect
#   https://YOUR_PROJECT_REF.supabase.co/auth/v1/callback
# Optional email hook: SUPABASE_SEND_EMAIL_HOOK_SECRET=v1,whsec_...

# ----------------------------------------------------------------------------
# PUBLIC APP URL — use HTTPS in production (Vercel + Supabase email links)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_APP_DOMAIN=manthana.quaasx108.com
# Local dev:
# NEXT_PUBLIC_APP_URL=http://localhost:3001
# Production (Vercel):
NEXT_PUBLIC_APP_URL=https://manthana.quaasx108.com

# ----------------------------------------------------------------------------
# ORACLE — browser uses same-origin proxy; server needs real backend URL
# ----------------------------------------------------------------------------
# Dev (Oracle on this machine):
# ORACLE_INTERNAL_URL=http://127.0.0.1:8100
# Production: HTTPS base of oracle-service (no trailing slash). Manthana: e.g.
# https://oracle.manthana.quaasx108.com (Railway custom domain) or https://*.up.railway.app until then.
ORACLE_INTERNAL_URL=https://your-oracle-or-gateway.example.com

NEXT_PUBLIC_GATEWAY_URL=/api/oracle-backend
NEXT_PUBLIC_API_URL=/api/oracle-backend
NEXT_PUBLIC_ORACLE_API_URL=/api/oracle-backend
# Kept for legacy client code paths; all route to Oracle proxy (Web/Research not deployed)
NEXT_PUBLIC_WEB_API_URL=/api/oracle-backend
NEXT_PUBLIC_RESEARCH_API_URL=/api/oracle-backend
NEXT_PUBLIC_ANALYSIS_API_URL=/api/oracle-backend
NEXT_PUBLIC_CLINICAL_API_URL=/api/oracle-backend

# NEXT_PUBLIC_ANALYSE_DEV_BYPASS_CONSENT_GATEWAY=1

# ----------------------------------------------------------------------------
# SLIM NAV — do not set FULL_MANTHANA_NAV in production Oracle+Labs-only deploy
# ----------------------------------------------------------------------------
# NEXT_PUBLIC_FULL_MANTHANA_NAV=1

# ----------------------------------------------------------------------------
# MANTHANA WEB (search UI) — keep locked when product is Oracle + Labs only
# ----------------------------------------------------------------------------
NEXT_PUBLIC_MANTHANA_WEB_LOCKED=true

# ----------------------------------------------------------------------------
# AWS / SES — receipts, optional custom auth email
# ----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

# ----------------------------------------------------------------------------
# RAZORPAY — if subscriptions are enabled
# ----------------------------------------------------------------------------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_BASIC_ID=
# Pro — ₹399/mo recurring plan id from Razorpay Dashboard
RAZORPAY_PLAN_PRO_ID=
# Pro Plus — create a ₹999/mo plan in Razorpay and paste its plan_id here (maps to internal plan "proplus")
RAZORPAY_PLAN_PROPLUS_ID=
# Legacy alias for proplus if PROPLUS unset
RAZORPAY_PLAN_ENTERPRISE_ID=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# ----------------------------------------------------------------------------
# Product access — free-tier Oracle fair-use (daily requests, signed-in + anon flows)
# ----------------------------------------------------------------------------
# Lower = stricter free tier. UI shows this in Plans & billing for transparency.
# FREE_ORACLE_DAILY_CAP=35

# ----------------------------------------------------------------------------
# OPTIONAL
# ----------------------------------------------------------------------------
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=
