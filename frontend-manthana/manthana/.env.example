# Better Auth (required for auth to work)
BETTER_AUTH_SECRET=    # Generate: openssl rand -base64 32
BETTER_AUTH_URL=       # e.g. http://localhost:3001 (dev) or https://manthana.ai (prod)

# Backend API (for rewrites)
NEXT_PUBLIC_API_URL=   # e.g. http://localhost:8000 (dev) or https://api.manthana.ai (prod)
# NEXT_PUBLIC_API_VERSION=  # Optional. Default /v1. Health is at /health (root), not /v1/health.

# Section-specific API URLs (Phase 1 — optional, fallback to NEXT_PUBLIC_API_URL)
# Ports: Oracle 8100, Web 8200, Research 8201, Analysis 8202
# NEXT_PUBLIC_ORACLE_API_URL=http://localhost:8100    # Oracle: /chat, /chat/m5
# NEXT_PUBLIC_WEB_API_URL=http://localhost:8200        # Web: /search, /search/autocomplete
# NEXT_PUBLIC_RESEARCH_API_URL=http://localhost:8201    # Research: /deep-research, /plagiarism/check
# NEXT_PUBLIC_ANALYSIS_API_URL=http://localhost:8202    # Analysis: /analyze/*, /report/*, /snomed/*
# NEXT_PUBLIC_CLINICAL_API_URL=  # Clinical: /drug-interaction/*, /herb-drug/*, /clinical-trials/*, /icd10/*
# Prevents "Failed to find Server Action" after rebuilds. Generate: openssl rand -base64 32
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=
