# Required for build/start (replace with your values)
# REQUIRED: MEILI_MASTER_KEY and MEILISEARCH_KEY must match; generate with: openssl rand -hex 32
# REQUIRED: DOMAIN, ACME_EMAIL for Traefik TLS
# REQUIRED for Oracle chat: set ONE of OPENROUTER_API_KEY or ORACLE_OPENROUTER_API_KEY (same secret; pick one name per deploy — see Oracle section below)
# OPTIONAL: N8N_*, GRAFANA_* (only needed with --profile monitoring)
DOMAIN=localhost
ACME_EMAIL=admin@example.com
MEILI_MASTER_KEY=change-me-use-openssl-rand-hex-32
MEILISEARCH_KEY=change-me-use-openssl-rand-hex-32
SEARXNG_SECRET=change-me-use-openssl-rand-hex-16
TRAEFIK_AUTH=
N8N_USER=admin
N8N_PASSWORD=change-me
N8N_ENCRYPTION_KEY=change-me-32-chars
GRAFANA_USER=admin
GRAFANA_PASSWORD=change-me
HF_TOKEN=

OLLAMA_URL=http://ollama:11434
QDRANT_URL=http://qdrant:6333
MEILISEARCH_URL=http://meilisearch:7700
# MEILISEARCH_KEY must match MEILI_MASTER_KEY (see above)
LOG_LEVEL=INFO
MAX_UPLOAD_MB=50
MEDITRON_MODEL=meditron
SUMMARY_MODEL=llama3.2
DEVICE=cpu
ENABLE_GPU=false

ECG_URL=http://ecg:8102
EYE_URL=http://eye:8103
CANCER_URL=http://cancer:8104
PATHOLOGY_URL=http://pathology:8105
BRAIN_URL=http://brain:8106
SEGMENTATION_URL=http://segmentation:8107
NLP_URL=http://nlp:8108
DRUG_URL=http://drug:8109
AYURVEDA_URL=http://ayurveda:8110
IMAGING_URL=http://imaging-utils:8111
INDEXER_URL=http://indexer:8112

# Perplexica internal search — never expose publicly
PERPLEXICA_URL=http://perplexica:3000

LITELLM_MASTER_KEY=sk-manthana-internal

# ═══════════════════════════════════════════════════════════════
#  OpenRouter — single cloud LLM key (replaces Groq/OpenAI direct for chat)
# ═══════════════════════════════════════════════════════════════
OPENROUTER_API_KEY=
# Path to repo config/cloud_inference.yaml (default inside Docker: /app/config/cloud_inference.yaml)
CLOUD_INFERENCE_CONFIG_PATH=
# Optional attribution headers for OpenRouter dashboard
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=Manthana

# ═══════════════════════════════════════════════════════════════
#  Oracle service (chat + M5)
# ═══════════════════════════════════════════════════════════════
# LLM: OpenRouter only (ORACLE_LLM_PROVIDER must be openrouter; legacy "groq" is not supported).
ORACLE_LLM_PROVIDER=openrouter
# Default false: no Meilisearch/Qdrant/Ollama embeddings/SearXNG/PubMed/ClinicalTrials calls.
# Set true to re-enable full RAG for /v1/chat and /v1/chat/m5.
ORACLE_USE_RAG=false
# Optional Oracle-prefixed keys — same OpenRouter secret as OPENROUTER_* above; pick one naming convention per deploy for the primary key so rotations stay obvious
ORACLE_OPENROUTER_API_KEY=
ORACLE_OPENROUTER_API_KEY_2=
# Override OpenRouter base URL (empty = use cloud_inference.yaml openrouter_base_url)
ORACLE_OPENROUTER_BASE_URL=
# Override models per role (empty = use cloud_inference.yaml; default oracle roles use moonshotai/kimi-k2.5)
ORACLE_OPENROUTER_MODEL=
ORACLE_OPENROUTER_MODEL_M5=

# ═══════════════════════════════════════════════════════════════
#  Manthana Web — optional free API keys (placeholders; paste when ready)
# ═══════════════════════════════════════════════════════════════
# NCBI — https://www.ncbi.nlm.nih.gov/account/ — higher PubMed rate limits (free)
NCBI_API_KEY=
# Semantic Scholar — https://www.semanticscholar.org/product/api — optional (free)
SEMANTIC_SCHOLAR_API_KEY=
# OpenAlex / Crossref polite pool — your contact email (recommended, no key)
OPENALEX_MAILTO=you@example.com
CROSSREF_MAILTO=
# CORE — https://core.ac.uk/services/api — optional future use
CORE_API_KEY=

# ═══════════════════════════════════════════════════════════════
#  Web service (optional — when deployed alongside frontend-manthana)
# ═══════════════════════════════════════════════════════════════
# When true, GET /v1/search returns 503 JSON { "status": "locked", "message": "..." }.
# Align with frontend NEXT_PUBLIC_MANTHANA_WEB_LOCKED for a coherent “paused” rollout.
WEB_FEATURE_LOCKED=false

# ═══════════════════════════════════════════════════════════════
#  PHASE 3: PER-SERVICE DATABASES (PostgreSQL)
#  Each service has its own isolated database for data separation
# ═══════════════════════════════════════════════════════════════

# Oracle Service Database
ORACLE_DB_PASSWORD=oracle_dev_password_change_me

# Web Service Database
WEB_DB_PASSWORD=web_dev_password_change_me

# Research Service Database
RESEARCH_DB_PASSWORD=research_dev_password_change_me

# Deep research: legacy RAG (Meili/Qdrant/…) vs hybrid (GPT Researcher + SearXNG only)
# Hybrid requires SearXNG + OPENROUTER_API_KEY (for GR LLM/embeddings via OpenRouter).
RESEARCH_USE_LEGACY_RAG=true

# Analysis Service Database
ANALYSIS_DB_PASSWORD=analysis_dev_password_change_me

