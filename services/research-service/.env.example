# Research Service — Production Configuration
# =============================================
# Copy to .env and customize for your deployment
#
# Architecture: Hybrid Deep Research (GPT Researcher + LangGraph + SearXNG)
# Fallback chain: SearXNG (primary) → Tavily (fallback) → DuckDuckGo (emergency)

# =============================================================================
# MODE SELECTION (Critical)
# =============================================================================

# Production: Use hybrid path (GPT Researcher + SearXNG/Tavily)
# Set to "true" only for legacy RAG mode (requires Meili/Qdrant/Perplexica)
RESEARCH_USE_LEGACY_RAG=false

# =============================================================================
# LLM CONFIGURATION (Required)
# =============================================================================

# OpenRouter API for synthesis (Required)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_API_KEY_2=  # Optional backup key for failover

# Hybrid LLM settings (auto-set, override if needed)
# RESEARCH_GR_LLM=openrouter:deepsearch/deepseek-chat
# RESEARCH_GR_EMBEDDING=openrouter:openai/text-embedding-3-small

# =============================================================================
# SEARCH RETRIEVERS (At least one required)
# =============================================================================

# PRIMARY: SearXNG self-hosted (Recommended for production)
SEARXNG_URL=http://searxng:8080

# FALLBACK: Tavily API (Higher quality, paid, optional)
# Sign up: https://tavily.com
# TAVILY_API_KEY=tvly-...
# TAVILY_ENABLED=false  # Set to true to enable fallback

# EMERGENCY: DuckDuckGo (Free, auto-enabled if others fail, slower)
# No configuration needed

# =============================================================================
# CACHING & PERFORMANCE (Recommended for 500-1000 users)
# =============================================================================

# Redis for search result caching (reduces API costs, improves latency)
RESEARCH_REDIS_URL=redis://redis:6379

# Cache TTL in seconds (default: 3600 = 1 hour)
# RESEARCH_CACHE_TTL=3600

# Hybrid tuning
# RESEARCH_HYBRID_MAX_STEPS=0          # 0 = auto from depth (focused/comprehensive/exhaustive)
# RESEARCH_HYBRID_TIMEOUT_SECONDS=0    # 0 = auto from depth budget

# =============================================================================
# DATABASE (Required for thread persistence)
# =============================================================================

# PostgreSQL for saved research threads
# DATABASE_URL=postgresql://research:password@research-db:5432/research_service
# RESEARCH_DB_PASSWORD=change_me_in_production

# =============================================================================
# LEGACY RAG SERVICES (Leave empty for hybrid-only mode)
# =============================================================================
# These are intentionally unset to disable legacy stack in production.
# Code is preserved for future reactivation if needed.

RESEARCH_MEILISEARCH_URL=""
RESEARCH_QDRANT_URL=""
RESEARCH_PERPLEXICA_URL=""
RESEARCH_OLLAMA_URL=""

# =============================================================================
# OPTIONAL FEATURES
# =============================================================================

# Plagiarism / Originality checking
# RESEARCH_ENABLE_PLAGIARISM=true
# RESEARCH_ENABLE_ORIGINALITY=true
# RESEARCH_PLAGIARISM_USE_QDRANT=false  # Set to true if Qdrant corpus available

# Citation configuration
# RESEARCH_ENABLE_CITATIONS=true
# RESEARCH_MAX_CITATIONS=25

# Rate limiting
# RESEARCH_RATE_LIMIT=60/minute

# =============================================================================
# EXAMPLE PRODUCTION .env
# =============================================================================
# 
# RESEARCH_USE_LEGACY_RAG=false
# SEARXNG_URL=http://searxng:8080
# TAVILY_API_KEY=tvly-abc123  # Optional premium fallback
# TAVILY_ENABLED=false
# RESEARCH_REDIS_URL=redis://redis:6379
# OPENROUTER_API_KEY=sk-or-v1-...
# DATABASE_URL=postgresql://research:secure_pass@db:5432/research
# 
# # Legacy services intentionally disabled
# RESEARCH_MEILISEARCH_URL=""
# RESEARCH_QDRANT_URL=""
# RESEARCH_PERPLEXICA_URL=""
