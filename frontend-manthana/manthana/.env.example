# ============================================================================
# MANTHANA LABS - REQUIRED ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your actual values
# ============================================================================

# ----------------------------------------------------------------------------
# BETTER AUTH (Authentication) - REQUIRED
# ----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Your app URL (MUST match what users see in browser)
# Dev: http://localhost:3001
# Prod: https://manthana.quaasx108.com
BETTER_AUTH_URL=http://localhost:3001

# ----------------------------------------------------------------------------
# AWS / AMAZON SES (Email) - REQUIRED for email verification & receipts
# ----------------------------------------------------------------------------
# Get from AWS IAM Console → Create user with AmazonSESFullAccess
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1  # or your preferred region (e.g., us-east-1)

# Your verified sending domain (must be verified in SES console)
NEXT_PUBLIC_APP_DOMAIN=manthana.quaasx108.com
# Dev: http://localhost:3001 — Prod: https://manthana.quaasx108.com (used in email links)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ----------------------------------------------------------------------------
# RAZORPAY (Payments) - REQUIRED for subscriptions
# ----------------------------------------------------------------------------
# Get from Razorpay Dashboard → Settings → API Keys
# For development, use test keys (rzp_test_...)
# For production, use live keys (rzp_live_...)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Create webhook in Razorpay Dashboard → Settings → Webhooks
# URL should be: https://yourdomain.com/api/razorpay/webhook
RAZORPAY_WEBHOOK_SECRET=

# Plan IDs from Razorpay Dashboard → Subscriptions → Plans
# Create these plans in Razorpay dashboard first, then copy IDs here
RAZORPAY_PLAN_BASIC_ID=  # Basic plan (e.g., ₹499/month)
RAZORPAY_PLAN_PRO_ID=     # Pro plan (e.g., ₹1999/month)
RAZORPAY_PLAN_ENTERPRISE_ID=  # Enterprise plan (custom pricing)

# Public key for frontend (same as RAZORPAY_KEY_ID but for client-side)
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# ----------------------------------------------------------------------------
# BACKEND API URLs (for AI services)
# ----------------------------------------------------------------------------
# Main gateway URL
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8000

# Individual service URLs (optional, fallback to main gateway)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_ORACLE_API_URL=http://localhost:8100    # Oracle: /chat, /chat/m5
NEXT_PUBLIC_WEB_API_URL=http://localhost:8200       # Web: /search, /search/autocomplete
NEXT_PUBLIC_RESEARCH_API_URL=http://localhost:8201  # Research: /deep-research, /plagiarism/check
NEXT_PUBLIC_ANALYSIS_API_URL=http://localhost:8202 # Analysis: /analyze/*, /report/*, /snomed/*
NEXT_PUBLIC_CLINICAL_API_URL=http://localhost:8203 # Clinical: drug interactions, trials, ICD10

# Oracle-only / remote dev: same-origin proxy (avoids browser → localhost:8100 when API runs in cloud/VM)
# ORACLE_INTERNAL_URL=http://127.0.0.1:8100
# NEXT_PUBLIC_ORACLE_API_URL=/api/oracle-backend
# NEXT_PUBLIC_API_URL=/api/oracle-backend
# Proxied by src/app/api/oracle-backend/[[...path]]/route.ts (streams SSE reliably).

# ----------------------------------------------------------------------------
# MANTHANA WEB (medical search UI) — feature flag
# ----------------------------------------------------------------------------
# When true or 1: /search and Oracle deep links to Web show a “Coming soon” experience;
# outbound calls in lib/api/web/* are short-circuited (no network to web-service for search).
# Set false locally if you are actively developing Manthana Web against a running web-service.
NEXT_PUBLIC_MANTHANA_WEB_LOCKED=true

# ----------------------------------------------------------------------------
# DATABASE (SQLite - managed by Better Auth)
# ----------------------------------------------------------------------------
# SQLite file is auto-created at ./auth.db in the project root
# For production with Postgres/MySQL, see Better Auth documentation

# ----------------------------------------------------------------------------
# OPTIONAL / DEBUG / ADVANCED
# ----------------------------------------------------------------------------
# NODE_ENV=development
# DEBUG=better-auth:*

# Prevents "Failed to find Server Action" after rebuilds
# Generate: openssl rand -base64 32
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=
